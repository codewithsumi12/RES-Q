{
  "rules": {
    "active_sos": {
      ".read": "auth != null",
      "$sosId": {
        ".write": "auth != null"
      }
    },
    "sos_locations": {
      ".read": "auth != null",
      "$sosId": {
        ".write": "auth != null"
      }
    },
    "sos_responders": {
      ".read": "auth != null",
      "$sosId": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    }
  }
}
